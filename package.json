{
  "name": "zenvy-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Zenvy AI - F-Commerce automation platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter backend db:generate",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:push": "pnpm --filter backend db:push",
    "db:studio": "pnpm --filter backend db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/engines", "prisma"]
  },
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "turbo": "^2.8.16"
  }
}
